#!/usr/bin/env bash
set -euo pipefail

files=()
while IFS= read -r file; do
  files+=("$file")
done < <(git diff --cached --name-only --diff-filter=ACMR -- '*.md')

if [ "${#files[@]}" -eq 0 ]; then
  exit 0
fi

if [ ! -x ./node_modules/.bin/markdownlint-cli2 ] || [ ! -x ./node_modules/.bin/textlint ]; then
  echo "Markdown lint tools are missing. Run: npm install" >&2
  exit 1
fi

./node_modules/.bin/markdownlint-cli2 "${files[@]}"
./node_modules/.bin/textlint "${files[@]}"
